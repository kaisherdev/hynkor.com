---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/index.css";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Hynkor Technologies es una compañia que comercializa computadoras de escritorio, laptops, tabletas, impresoras, suministros de impresión, accesorios y software (Windows 11, Oficce 365, antivirus, etc)."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot name="hero" />
    <main class="max-w-7xl mx-auto px-4 py-12">
      <slot />
    </main>
    <Footer />
  </body>
</html>
