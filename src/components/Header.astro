---
import SocialPill from "../components/SocialPill.astro";
import BurgerButton from "../assets/icons/Hamburger.astro";
import CloseIcon from "../assets/icons/Close.astro";
import { CartCount } from "./CartCount";
import { CartPanel } from "./CartPanel";

const menuitems = [
	{
		title: "Inicio",
		label: "inicio",
		url: "/",
	},
	{
		title: "Productos",
		label: "productos",
		url: "/#products",
	},
	{
		title: "Categorías",
		label: "categorías",
		url: "/#categories",
	},
	{
		title: "Servicios",
		label: "Servicios",
		url: "/#services",
	},
];

const logoAlt = "Logo de Hynkor Technologies";
---

<header class="w-full fixed border-b top-0 z-50 text-white">
	<nav
		class="flex justify-between items-center gap-8 h-16 lg:max-w-5xl lg:mx-auto mx-4 m-2"
	>
		<div class="flex lg:w-auto w-full items-center justify-between">
			<a href="/">
				<img src="/logo.svg" alt={logoAlt} class="lg:size-14 size-12" />
			</a>
			<!-- <CartCount client:load /> -->
			<div class="flex lg:hidden">
				<button type="button" id="open-menu-button" class="cursor-pointer">
					<span class="sr-only">Abrir Menú Principal</span>
					<BurgerButton />
				</button>
			</div>
		</div>
		<div class="hidden lg:w-auto w-full mt-2 lg:flex lg:mt-0">
			<ul class="flex flex-col lg:flex-row lg:gap-3">
				{
					menuitems.map(({ title, url, label }) => (
						<>
							<li class="hover:border-b hover:border-b-indigo-400">
								<a
									href={url}
									aria-label={label}
									class="flex lg:px-3 py-2 items-center justify-center hover:text-gray-300 "
								>
									<span> {title}</span>
								</a>
							</li>
						</>
					))
				}
			</ul>
		</div>
		<div class="flex gap-2">
			<div class="hidden lg:flex items-center gap-4">
				<SocialPill
					aria-hidden="true"
					href="mailto:hynkor.dreadlock534@passinbox.com"
					class="hidden lg:inline-block bg-[#0d958c] px-6 py-3 rounded-full hover:bg-emerald-400 hover:text-white text-sm font-semiboldS"
				>
					Escríbenos
				</SocialPill>
			</div>
			<CartCount client:load />
		</div>
	</nav>

	<dialog
		id="mobile-menu"
		role="dialog"
		aria-modal="true"
		class="transition-(display) p-4 lg:hidden size-full max-h-full max-w-full translate-x-0 transform transition-all ease-in-out duration-300 starting:-translate-x-full [&:not([open])]:-translate-x-full z-40"
	>
		<div class="overflow-y-auto z-10">
			<div>
				<div class="flex flex-1 justify-between items-center m-2">
					<button
						type="button"
						id="close-menu-button"
						class="cursor-pointer transition-all duration-300 ease-in will-change-transform hover:scale-150"
					>
						<span class="sr-only">Cerrar Menú</span>
						<CloseIcon />
					</button>
					<div class="text-xl font-bold">Menú</div>
				</div>
			</div>
			<div class="flex flex-col items-center justify-center">
				<ul class="flex flex-col lg:flex-row lg:gap-3">
					{
						menuitems.map(({ title, url, label }) => (
							<>
								<li>
									<a
										href={url}
										aria-label={label}
										class="flex lg:px-3 py-2 items-center justify-center text-lg hover:text-gray-900"
									>
										<span class="font-bold"> {title}</span>
									</a>
								</li>
							</>
						))
					}
				</ul>
				<div class="flex justify-center items-center w-full">
					<SocialPill
						href="mailto:hynkor.dreadlock534@passinbox.com"
						class="border border-gray p-2 rounded-lg hover:bg-green-300 hover:text-slate-400"
					>
						Escríbenos
					</SocialPill>
				</div>
			</div>
		</div>
	</dialog>
</header>
<CartPanel client:load />
<style>
	header {
		background: transparent;
		animation: header-blur-scroll linear both;
		animation-timeline: scroll();
		animation-range: 0 250px;
		border-bottom: 1px solid transparent;
	}

	@keyframes header-blur-scroll {
		0% {
			background: transparent;
			backdrop-filter: blur(0px);
		}
		100% {
			backdrop-filter: blur(10px);
			background: rgba(99, 100, 99, 0.4);
			border-bottom-color: rgb(164, 162, 162);
		}
	}
</style>

<script>
	// Get the menu elements
	const mobileMenu = document.getElementById(
		"mobile-menu",
	) as HTMLDialogElement;
	const openMenuButton = document.getElementById("open-menu-button");
	const closeMenuButton = document.getElementById("close-menu-button");
	const mobileItems = mobileMenu.querySelectorAll("a");

	const toggleMenu = () => {
		mobileMenu.open ? mobileMenu.close() : mobileMenu.showModal();
	};

	// Add event listener to open menu button
	openMenuButton?.addEventListener("click", toggleMenu);

	// Add event listener to close menu button
	closeMenuButton?.addEventListener("click", toggleMenu);

	document.addEventListener("click", (event) => {
		const isClickInsideMenu = mobileMenu.contains(event.target as Node);
		const isClickInsideButton = openMenuButton?.contains(event.target as Node);

		if (isClickInsideMenu && !isClickInsideButton) {
			mobileMenu.close();
		}
	});

	mobileItems?.forEach((item) => item.addEventListener("click", toggleMenu));
</script>
