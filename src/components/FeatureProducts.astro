---
import { supabase } from "../db/supabase";
import Card from "../components/Card.astro.astro";

const { data: products } = await supabase.from("products").select("*");
---

<section id="products" class="mt-16">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl mb-4">Productos destacados</h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Selección especial de nuestros productos más populares con la mejor
        relación calidad-precio
      </p>
    </div>
  </div>
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
  >
    {
      (products ?? []).map((p) => (
        <Card
          id={p.id}
          name={p.name}
          image_url={p.image_url}
          price={p.price}
          category={p.category}
        />
      ))
    }
  </div>
</section>
