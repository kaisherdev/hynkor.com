---
import Laptop from "../assets/icons/Laptop.astro";
import Printer from "../assets/icons/Printer.astro";
import Tablet from "../assets/icons/Tablet.astro";
import Monitor from "../assets/icons/Monitor.astro";
import Shield from "../assets/icons/Shield.astro";
import Cable from "../assets/icons/Cable.astro";
import Droplet from "../assets/icons/Droplet.astro";

const categories = [
  {
    icon: Laptop,
    title: "Laptops",
    description: "Portátiles para trabajo y gaming",
    color: "bg-blue-100 text-blue-600",
  },
  {
    icon: Printer,
    title: "Impresoras",
    description: "Impresoras multifuncionales",
    color: "bg-purple-100 text-purple-600",
  },
  {
    icon: Tablet,
    title: "Tabletas",
    description: "Tablets para productividad",
    color: "bg-pink-100 text-pink-600",
  },
  {
    icon: Monitor,
    title: "Computadoras",
    description: "PCs de escritorio potentes",
    color: "bg-green-100 text-green-600",
  },
  {
    icon: Droplet,
    title: "Tintas",
    description: "Cartuchos y toners originales",
    color: "bg-cyan-100 text-cyan-600",
  },
  {
    icon: Cable,
    title: "Accesorios",
    description: "Mouse, teclados y más",
    color: "bg-orange-100 text-orange-600",
  },
  {
    icon: Shield,
    title: "Software",
    description: "Windows, Office, antivirus",
    color: "bg-red-100 text-red-600",
  },
];
---

<section id="categories" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl mb-4">Categorías de Productos</h2>
      <p class="text-gray-600 max-w-2xl mx-auto text-lg tracking-wide">
        Encuentra todo lo que necesitas para equipar tu oficina o mejorar tu
        setup tecnológico
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        categories.map((category) => (
          <div class="group hover:shadow-lg transition-all duration-300 cursor-pointer border-2 hover:border-blue-600 rounded-xl">
            <div class="p-6 text-center space-y-4">
              <div
                class={`inline-flex p-4 rounded-full ${category.color}  group-hover:scale-110 transition-transform`}
              >
                <category.icon size="8" />
              </div>
              <div>
                <h3 class="text-xl mb-2">{category.title}</h3>
                <p class="text-sm text-gray-600">{category.description}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
