---

<section
	id="hero-slider"
	class="relative overflow-hidden bg-slate-950 text-white shadow-2xl shadow-slate-900/40 w-full"
>
	<div class="relative min-h-112 sm:min-h-136 lg:min-h-160">
		{
			slides.map((slide, index) => (
				<article
					data-hero-slide
					data-index={index}
					class={`absolute inset-0 transition-all duration-700 ease-in-out ${index === 0 ? "opacity-100 translate-x-0" : "opacity-0 translate-x-8"}`}
					aria-hidden={index !== 0}
				>
					<img
						src={slide.image}
						alt={slide.alt}
						class="absolute inset-0 h-full w-full object-cover"
					/>
					<div class="absolute inset-0 bg-linear-to-t from-slate-950/95 via-slate-950/50 to-slate-950/20" />
					<div class="relative flex h-full flex-col justify-center px-2 py-4 sm:px-6 lg:px-16">
						<span class="inline-flex items-center rounded-full border border-emerald-300/25 bg-emerald-300/10 px-3 py-1 text-xs uppercase tracking-[0.32em] text-emerald-300 mb-5 mx-auto">
							{slide.label}
						</span>
						<h2 class="text-lg sm:text-4xl lg:text-6xl font-black leading-tight tracking-[-0.04em] text-white">
							{slide.title}
						</h2>
						<p class="mt-5 max-w-2xl text-base sm:text-lg text-slate-200 text-balance">
							{slide.description}
						</p>
					</div>
				</article>
			))
		}
	</div>

	<div
		class="absolute inset-x-0 bottom-8 mx-auto flex max-w-7xl flex-col gap-4 px-6 sm:flex-row sm:items-center sm:justify-between sm:px-10 lg:px-16"
	>
		<div class="flex flex-wrap gap-3">
			<a
				href="#products"
				class="inline-flex items-center justify-center rounded-full bg-[#0d958c] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/30 transition hover:bg-emerald-400"
			>
				Ver productos
			</a>
			<a
				href="mailto:hynkor.dreadlock534@passinbox.com?subject=Solicitud%20de%20cotización"
				class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/15"
			>
				Solicitar cotización
			</a>
		</div>
	</div>

	<div class="absolute bottom-4 right-4 flex items-center gap-2">
		{
			slides.map((_, index) => (
				<button
					type="button"
					data-hero-indicator
					data-index={index}
					class="h-3 w-3 rounded-full bg-white/40 transition hover:bg-white"
					aria-label={`Seleccione la imagen ${index + 1}`}
				/>
			))
		}
	</div>

	<script is:inline>
		const root = document.getElementById("hero-slider");
		if (root) {
			const slides = Array.from(root.querySelectorAll("[data-hero-slide]"));
			const indicators = Array.from(
				root.querySelectorAll("[data-hero-indicator]"),
			);
			let currentIndex = 0;
			let timer;

			const setActive = (index) => {
				currentIndex = index;
				slides.forEach((slide, slideIndex) => {
					const active = slideIndex === currentIndex;
					slide.classList.toggle("opacity-100", active);
					slide.classList.toggle("translate-x-0", active);
					slide.classList.toggle("pointer-events-none", !active);
					slide.classList.toggle("opacity-0", !active);
					slide.classList.toggle("translate-x-8", !active);
					slide.setAttribute("aria-hidden", String(!active));
				});

				indicators.forEach((button, buttonIndex) => {
					button.classList.toggle("bg-white", buttonIndex === currentIndex);
					button.classList.toggle("bg-white/40", buttonIndex !== currentIndex);
				});
			};

			const nextSlide = () => {
				setActive((currentIndex + 1) % slides.length);
			};

			root.addEventListener("click", (event) => {
				const button = event.target.closest("[data-hero-indicator]");
				if (!button) return;
				const selectedIndex = Number(button.dataset.index);
				if (!Number.isNaN(selectedIndex)) {
					setActive(selectedIndex);
					window.clearInterval(timer);
					timer = window.setInterval(nextSlide, 7000);
				}
			});

			timer = window.setInterval(nextSlide, 7000);
			setActive(0);
		}
	</script>
</section>
